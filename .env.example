# Supabase project credentials
# Copy this file to .env and fill in your values

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key-from-supabase-dashboard>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-from-supabase-dashboard>

# Database connection (pooler)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-eu-central-1.pooler.supabase.com:5432/postgres

# SMTP (used by supabase config push via env(SMTP_PASSWORD) in config.toml)
SMTP_PASSWORD=<smtp-password>
