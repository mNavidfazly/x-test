# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...                    # service_role key (bypasses RLS)
SUPABASE_JWT_SECRET=xxx                        # Settings > API > JWT Secret

# Email (Calypso SMTP via Office 365)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=support@calypso-commodities.com
SMTP_PASSWORD=xxx
FROM_EMAIL=noreply@calypso-commodities.com

# CORS
CORS_ORIGINS=["http://localhost:4200","https://x-courses-v2.vercel.app"]

# Bunny Stream
BUNNY_API_KEY=xxx                                 # Bunny Stream API key
BUNNY_LIBRARY_ID=0                                # Bunny video library ID
BUNNY_CDN_HOSTNAME=vz-xxx.b-cdn.net               # Bunny CDN pull zone hostname
BUNNY_TOKEN_KEY=xxx                               # Bunny token authentication key
